#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# Block direct commits on main to enforce PR-based review flow.
# Emergency override only with explicit user approval per task.
current_branch="$(git rev-parse --abbrev-ref HEAD)"
if [[ "$current_branch" == "main" && "${ALLOW_MAIN_COMMIT:-}" != "1" ]]; then
  echo "[pre-commit] Direct commits on 'main' are blocked." >&2
  echo "[pre-commit] Create a short-lived branch and commit there for PR review:" >&2
  echo "[pre-commit]   ./scripts/start_wip_branch.sh <ticket-or-scope>" >&2
  echo "[pre-commit]   # or: git switch -c codex/wip-<ticket-or-scope>" >&2
  echo "[pre-commit] Emergency override (user-approved only): ALLOW_MAIN_COMMIT=1 git commit ..." >&2
  exit 1
fi

# Fail fast on unintended WORKLOG_TICKETS edits (even if unstaged).
# Explicit curation can override with ALLOW_WORKLOG_TICKETS_EDIT=1.
if [[ "${ALLOW_WORKLOG_TICKETS_EDIT:-}" != "1" ]]; then
  if git diff --name-only | grep -q '^docs/WORKLOG_TICKETS.md$'; then
    echo "[pre-commit] docs/WORKLOG_TICKETS.md has unstaged local edits." >&2
    echo "[pre-commit] Use docs/WORKLOG_ADDENDUM_*.md for active updates." >&2
    echo "[pre-commit] If this is intentional curation, rerun with ALLOW_WORKLOG_TICKETS_EDIT=1." >&2
    exit 1
  fi
fi

# 1. Agent gate: worklog enforcement
./scripts/agent_gate.sh --staged

# 2. Secret scan: block commits that include leaked credentials
# Skip with SKIP_SECRET_SCAN=1 or --no-verify
if [[ "${SKIP_SECRET_SCAN:-}" != "1" ]]; then
  ./scripts/secret_scan.sh --staged
else
  echo "[pre-commit] Skipping secret scan (SKIP_SECRET_SCAN=1)"
fi

# 3. Feature regression check: detect removed functionality in large refactors
# Triggered when >10% LOC changed in existing files
# Skip with SKIP_FEATURE_CHECK=1 or --no-verify
if [[ "${SKIP_FEATURE_CHECK:-}" != "1" ]]; then
  ./scripts/feature_regression_check.sh --staged
else
  echo "[pre-commit] Skipping feature regression check (SKIP_FEATURE_CHECK=1)"
fi

# 4. Regression check: tests + export comparison + TypeScript
# Skip with SKIP_REGRESSION_CHECK=1 or --no-verify
if [[ "${SKIP_REGRESSION_CHECK:-}" != "1" ]]; then
  ./scripts/regression_check.sh --staged
else
  echo "[pre-commit] Skipping regression check (SKIP_REGRESSION_CHECK=1)"
fi
