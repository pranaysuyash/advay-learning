#!/bin/bash
#
# Pre-push hook to run deployment checks
# This prevents pushing code that would break production
#

set -e

echo "🔍 Running pre-push deployment checks..."
echo ""

# Check if we're in the backend directory context
cd "$(git rev-parse --show-toplevel)"

# Activate virtual environment if it exists
if [ -f ".venv/bin/activate" ]; then
    source .venv/bin/activate
fi

# Run deployment checks
if ! python scripts/pre_deploy_check.py; then
    echo ""
    echo "❌ Pre-push checks failed!"
    echo "Fix the issues above before pushing."
    exit 1
fi

echo ""
echo "✅ All pre-push checks passed!"
exit 0
